# Copy to .env and change every secret before exposing beyond localhost.
DJANGO_SECRET_KEY=change-me-use-openssl-rand-hex-32
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://ocg:change-me@db:5432/ocg_aggregator
POSTGRES_DB=ocg_aggregator
POSTGRES_USER=ocg
POSTGRES_PASSWORD=change-me
CARD_CATALOG_PATH=/catalog/cards.json
TZ=Asia/Singapore
SCRAPE_INTERVAL_HOURS=6
SCRAPER_USER_AGENT=OCG Aggregator self-hosted price checker/0.1
ADMIN_PASSWORD=

